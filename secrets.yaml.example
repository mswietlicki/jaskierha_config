# secrets.yaml - copy this to secrets.yaml and fill in values
# Or use setup-secrets.sh to generate it from environment variables.
#
# Required environment variables:
#   SAMBA_PASSWORD   - password for the Samba Share add-on
#   WIFI_SSID        - Wi-Fi network name (used by ESPHome devices)
#   WIFI_PASSWORD    - Wi-Fi network password (used by ESPHome devices)

samba_password: !env_var SAMBA_PASSWORD
wifi_ssid: !env_var WIFI_SSID
wifi_password: !env_var WIFI_PASSWORD
